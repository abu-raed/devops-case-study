# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
PORT=5000

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy+dum
# AWS_SESSION_TOKEN=       # only needed for temporary credentials (STS)
AWS_REGION=us-east-1

# S3 bucket to store uploaded CSVs
S3_BUCKET=s3://devops-case-kops-state-kubeios

# Prefix (folder) inside the bucket
S3_PREFIX=csv-uploads/

# ── Glacier Lifecycle ─────────────────────────────────────────────────────────
# After this many days objects transition to S3 Glacier Instant Retrieval (GLACIER_IR).
# 90 days later they move to Glacier Deep Archive.
GLACIER_TRANSITION_DAYS=30
